    { "name": "online_update", "module": "mitooshi.cells.online_update", "murakumoNode": "judah", "phase": "residual → EWMA bias + variance-inflation recalibration (baien-edge); proposes a new model version", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.mitooshi.modelUpdateAttestation", "gates": ["G8", "G9"] },
