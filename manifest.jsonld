  "constitutionalGates": {
    "description": "12 immutable gates per ADR-2606051800. G1 (distribution-only/no-point-assertion) + G2 (non-speculative/no-trading) + G5 (leak-free proper-scoring) are the structural anchors; G4 (primary-public-only) inherits the kanjo §2(c)/(e) anti-gatekeeping precedent.",
    "gates": {
      "G1": "Distribution-only — :forecast/point-asserted :db/allowed [false] + lexicon const false + ValueError; deterministic single-future unrepresentable (非終末論)",
      "G2": "Non-speculative — :forecast/use enum excludes trade/speculation/wager/position; never trades (Charter §1.3 + yobel)",
      "G3": "Non-adjudicating — routes forecasts to planners; no advice/rating/valuation (kanjo boundary, not 投資助言業)",
      "G4": "Primary-public-only — :series/source-class enum excludes proprietary terminals + scraped Google-Trends (kanjo §2(c)/(e))",
      "G5": "Leak-free proper-scoring — info-as-of boundary enforced; CRPS/pinball/Brier/log-score; skill vs documented baseline",
      "G6": "Murakumo-only inference (ADR-2605215000)",
      "G7": "Calibration-honest — PIT reliability reported; miscalibrated model refused promotion",
      "G8": "Baien-edge online-update — recalibration on baien federated edge only; commercial GPU rejected (ADR-2605215000/2605241900)",
      "G9": "No-server-key — model promotion member/operator-signed; server signature refused (ADR-2605231525)",
      "G10": "Outward-gated — live ingest/publish/promotion/backward-pass Council Lv6+ + operator",
      "G11": "Sourcing-honesty — :representative seed; primary-source verification before outward use",
      "G12": "Anti-pseudoscience — :skilled true ONLY when beating a documented baseline on a proper score (kizashi G10 precedent)"
    }
  },
  "nonGoals": {
    "description": "7 explicitly excluded scopes",
    "goals": {
