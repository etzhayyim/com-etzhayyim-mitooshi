{:lexicon 1
 :id "com.etzhayyim.mitooshi.scoreResidual"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["forecastId" "obsId" "derived"]
    :properties
    {:forecastId {:type "string" :description "→ :forecast/id"}
     :obsId      {:type "string" :description "→ :obs/id; G5 — :obs/observed-at MUST be > forecast :info-as-of"}
     :crps       {:type "number" :description "Continuous Ranked Probability Score (lower better)"}
     :pinball    {:type "number" :description "mean pinball / quantile loss"}
     :logScore   {:type "number" :description "negative log predictive density"}
     :brier      {:type "number" :description "categorical only"}
     :pit        {:type "number" :description "F(y) ∈ [0,1] — Uniform if calibrated"}
     :skill      {:type "number" :description "1 − score_model/score_baseline; >0 = beats baseline"}
     :baselineId {:type "string" :description "→ :baseline/id (climatology/persistence/random-walk)"}
     :derived    {:type "boolean" :const true
                  :description "INVARIANT — a score is DERIVED; never re-ingested as authoritative fact"}}}}}}
